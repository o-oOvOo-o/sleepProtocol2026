    "litepaper": {
      "tableOfContents": "Table of Contents",
      "ethos": {
        "title": "Our Ethos: A Fair Launch Reimagined",
        "p1": "Sleep Coin is born from the core principles of Proof-of-Participation, but re-engineered to address the economic vulnerabilities of first-generation fair launch tokens. We believe in a system that is transparent, equitable, and sustainable.",
        "p2": "Our philosophy is built on four pillars:",
        "pillar1": "Verifiable Scarcity",
        "pillar1Text": "Unlike tokens with infinite inflation, Sleep Coin has an almost predictable hard cap (the number of minted tokens when reaching the soft cap is negligible ~ cycle is about 1.5-2 years), with significant production reduction within one year. Value is derived from scarcity.",
        "pillar2": "Economic Sustainability",
        "pillar2Text": "Through minting fees and dynamic transaction tax systems, the protocol generates its own liquidity and staker rewards, creating a self-sustaining economic loop without relying on external funding. Transaction fees prevent malicious batch minting by bots and large holders.",
        "pillar3": "Manipulation Resistance",
        "pillar3Text": "The tokenomics are designed to deter whales and reward long-term participants. The Population Pressure mechanism ensures that as more people join, the inflation rate automatically adjusts, preventing the system from being controlled by a few.",
        "pillar4": "Complete Decentralization",
        "pillar4Text": "All minting taxes and transaction taxes are completely used for protocol liquidity and staker rewards, with no reserved team funds. All admin privileges in the testnet test contracts have been discarded and related code deleted, with no admin privileges whatsoever."
      },
      "tokenomics": {
        "title": "Tokenomics: A Symphony of Mechanisms",
        "intro": "Every mechanism in Sleep Coin is designed to work in concert, creating a balanced and robust economic model.",
        "keyMetrics": "Key Metrics",
        "totalSupply": "Total Supply",
        "mintingMechanism": "Minting Mechanism",
        "stakingRewards": "Staking Rewards",
        "feeStructure": "Fee Structure"
      },
      "mintFee": {
        "title": "Minting Fee (0.01 OKB)",
        "content": "A small flat fee per mint batch (up to 100 units) serves as a critical anti-bot measure. This fee is the primary source of initial funding for the protocol's liquidity and staking rewards, ensuring the system can bootstrap itself from day one.",
        "tip": "Pro Tip: The fee structure prevents spam while funding the ecosystem!"
      },
      "dynamicTerm": {
        "title": "Dynamic Max Term",
        "content": "The maximum minting term starts at 45 days and increases by 1 day every 3 days. This gives later participants a fair chance to leverage the 'time weapon' against early minters, balancing the playing field over the first year.",
        "timeline": "Timeline: 45 days → +1 day every 3 days → Leveling the field!"
      },
      "populationPressure": {
        "title": "Population Pressure (Amplifier Adjustment)",
        "content": "The Reward Amplifier, a key component in the minting formula, is not static. For every 100,000 new global ranks, the base amplifier is reduced by 2%. This acts as a natural brake on inflation as the user base grows, ensuring long-term sustainability.",
        "important": "Important: More users = Lower inflation! Smart economics!"
      },
      "timeDecay": {
        "title": "Time Decay (Exponential Reduction)",
        "content": "A powerful exponential decay function is applied to the mint reward calculation. This ensures that minting rewards gradually trend towards near-zero after one year, creating a finite emission window and establishing a clear end to the inflationary phase.",
        "result": "Result: Finite supply + Decreasing inflation = Value preservation!"
      },
      "tax": {
        "title": "Transaction Tax",
        "content": "Transaction tax is designed to reward long-term holders and fund the ecosystem. The tax is structured in two phases:",
        "phase1": "Phase 1 (First Year):",
        "phase1Tax": "2% Buy Tax / 4% Sell Tax",
        "phase2": "Phase 2 (After One Year):",
        "phase2Tax": "0% Buy Tax / 1% Sell Tax"
      },
      "feeDistribution": {
        "title": "Fee Distribution",
        "content": "All fees collected by the protocol (from minting and taxes) are distributed programmatically:",
        "beforeRank": "Before Global Rank reaches 100,000:",
